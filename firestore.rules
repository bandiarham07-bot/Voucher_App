rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() { return request.auth != null && request.auth.uid == "WWJdXATalpg8ekf1qyhulua7gTi2"; }
    match /vouchers/{voucherId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null && (isAdmin() || request.resource.data.ownerId == request.auth.uid);
      allow update: if request.auth != null && (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid));
      allow delete: if request.auth != null && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }
    match /vendors/{id} { allow read, write: if request.auth != null; }
    match /accounts/{id} { allow read, write: if request.auth != null; }
  }
}
